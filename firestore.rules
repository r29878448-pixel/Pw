rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Config collection - only admin can write, everyone can read
    match /config/{document=**} {
      allow read: if true;  // Anyone can read config
      allow write: if request.auth != null && request.auth.token.email == 'adityaghoghari01@gmail.com';  // Only admin can write
    }
    
    // Custom Batches collection - only admin can write, everyone can read
    match /customBatches/{batchId} {
      allow read: if true;  // Anyone can read custom batches
      allow write: if request.auth != null && request.auth.token.email == 'adityaghoghari01@gmail.com';  // Only admin can write
    }
    
    // Batch Edits collection - only admin can write, everyone can read
    // This stores thumbnail and name edits for both custom and default batches
    match /batchEdits/{batchId} {
      allow read: if true;  // Anyone can read batch edits
      allow write: if request.auth != null && request.auth.token.email == 'adityaghoghari01@gmail.com';  // Only admin can write
    }
    
    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

